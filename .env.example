# https://docs.x.com/x-api/getting-started/getting-access
# For reading public posts you only need Bearer Token (app-only auth).

X_BEARER_TOKEN=

# Cloudflare deploy from the Linux server (create at dash.cloudflare.com → My Profile → API Tokens)
# Needs D1, R2, and Pages edit permissions for your account.
# CLOUDFLARE_API_TOKEN=

# Optional: only needed to mint a bearer via X OAuth (console.x.com is easier)
# X_API_KEY=
# X_API_SECRET=
