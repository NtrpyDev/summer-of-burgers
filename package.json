{
  "name": "bc-burger-tracker",
  "version": "0.1.0",
  "private": true,
  "description": "Big Cat Summer of Burgers fan archive, gallery, and voting games.",
  "type": "module",
  "scripts": {
    "dev": "node scripts/dev-server.cjs",
    "collector": "node scripts/collector.cjs",
    "collector:list": "node scripts/collector.cjs --list-campaign",
    "share-cards": "node scripts/generate-share-cards.cjs",
    "normalize": "node scripts/normalize-archive.cjs",
    "audit:prod": "npm audit --omit=dev --audit-level=high",
    "test": "node scripts/smoke-test.cjs"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "4.20260528.1",
    "wrangler": "4.95.0"
  },
  "dependencies": {
    "@huggingface/transformers": "4.2.0",
    "@xdevplatform/xdk": "0.5.0",
    "sharp": "0.34.5"
  },
  "overrides": {
    "sharp": "$sharp"
  }
}
